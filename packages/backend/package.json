{
    "name": "@cellix/backend",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "./src/server.ts",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/server.js",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@cellix/shared": "workspace:*",
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^9.0.1",
        "@fastify/jwt": "^10.0.0",
        "@fastify/redis": "^7.2.0",
        "bcrypt": "^6.0.0",
        "drizzle-orm": "^0.45.2",
        "fastify": "^4.28.1",
        "fastify-plugin": "^5.1.0",
        "pino-pretty": "^13.1.3",
        "postgres": "^3.4.9",
        "xlsx": "^0.18.5",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/node": "^20.14.9",
        "drizzle-kit": "^0.31.10",
        "tsx": "^4.16.2",
        "typescript": "^5.4.5"
    }
}
