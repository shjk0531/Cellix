{
    "name": "@cellix/backend",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "./src/server.ts",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/server.js",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@cellix/shared": "workspace:*",
        "@nestjs/common": "^11.1.20",
        "@nestjs/core": "^11.1.20",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/platform-express": "^11.1.20",
        "drizzle-orm": "^0.45.2",
        "ioredis": "^5.10.1",
        "pino-pretty": "^13.1.3",
        "postgres": "^3.4.9",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "xlsx": "^0.18.5",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^25.7.0",
        "dotenv": "^17.4.2",
        "drizzle-kit": "^0.31.10",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3"
    }
}
