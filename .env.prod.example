# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Backend ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
CORS_ORIGIN=http://your-domain.com

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=cellix
POSTGRES_USER=cellix
POSTGRES_PASSWORD=strong_password_here

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=strong_redis_password_here
